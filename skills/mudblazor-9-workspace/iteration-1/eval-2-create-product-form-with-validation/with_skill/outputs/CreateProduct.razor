@page "/products/new"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations

@inject ProductService ProductService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Create product</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Create product</MudText>

<EditForm Model="@_model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />

    <MudGrid Spacing="4">
        <MudItem xs="12">
            <MudTextField @bind-Value="_model.Name"
                          For="@(() => _model.Name)"
                          Label="Name"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Name is required"
                          Immediate="true" />
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="_model.Sku"
                          For="@(() => _model.Sku)"
                          Label="SKU"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="SKU is required"
                          HelperText="Format: ABC-1234"
                          Immediate="true" />
        </MudItem>

        <MudItem xs="12">
            <MudNumericField @bind-Value="_model.Price"
                             For="@(() => _model.Price)"
                             Label="Price"
                             Variant="Variant.Outlined"
                             Required="true"
                             RequiredError="Price is required"
                             Format="C2"
                             Culture="@System.Globalization.CultureInfo.CurrentCulture"
                             HideSpinButtons="true" />
        </MudItem>

        <MudItem xs="12">
            <MudSelect T="string" @bind-Value="_model.Category"
                       For="@(() => _model.Category)"
                       Label="Category"
                       Variant="Variant.Outlined"
                       Required="true"
                       RequiredError="Category is required">
                <MudSelectItem Value="@("Electronics")">Electronics</MudSelectItem>
                <MudSelectItem Value="@("Clothing")">Clothing</MudSelectItem>
                <MudSelectItem Value="@("Food")">Food</MudSelectItem>
            </MudSelect>
        </MudItem>

        <MudItem xs="12">
            <MudCheckBox T="bool" @bind-Value="_model.InStock" Label="In stock" Color="Color.Primary" />
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="_model.Description"
                          For="@(() => _model.Description)"
                          Label="Description"
                          Variant="Variant.Outlined"
                          Lines="4"
                          Counter="500"
                          MaxLength="500" />
        </MudItem>

        <MudItem xs="12">
            <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           OnClick="HandleCancel"
                           Disabled="@_saving">
                    Cancel
                </MudButton>
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="@_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Saving</MudText>
                    }
                    else
                    {
                        <MudText>Create product</MudText>
                    }
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</EditForm>

@code {
    private CreateProductModel _model = new();
    private bool _saving;

    private async Task HandleValidSubmit()
    {
        _saving = true;
        try
        {
            await ProductService.CreateAsync(_model);
            Snackbar.Add("Product created", Severity.Success);
            _model = new();
        }
        finally
        {
            _saving = false;
        }
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/products");
    }

    public class CreateProductModel
    {
        [Required(ErrorMessage = "Name is required")]
        [StringLength(100, MinimumLength = 3, ErrorMessage = "Name must be between 3 and 100 characters")]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "SKU is required")]
        [RegularExpression(@"^[A-Z]{3}-\d{4}$", ErrorMessage = "SKU must match format ABC-1234")]
        public string Sku { get; set; } = "";

        [Required(ErrorMessage = "Price is required")]
        [Range(0.01, double.MaxValue, ErrorMessage = "Price must be greater than 0")]
        public decimal Price { get; set; }

        [Required(ErrorMessage = "Category is required")]
        public string Category { get; set; } = "";

        public bool InStock { get; set; }

        [StringLength(500, ErrorMessage = "Description cannot exceed 500 characters")]
        public string? Description { get; set; }
    }
}
