@page "/users"
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserService UserService

<MudText Typo="Typo.h4" GutterBottom="true">Users</MudText>

<MudStack Row="true" Class="mb-4">
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateUserDialog">
        New user
    </MudButton>
    <MudSpacer />
    <MudMenu>
        <ActivatorContent>
            <MudButton Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.MoreVert">
                More actions
            </MudButton>
        </ActivatorContent>
        <ChildContent>
            <MudMenuItem OnClick="ExportToCsv">Export CSV</MudMenuItem>
            <MudMenuItem OnClick="OpenBulkImportDialog">Bulk import</MudMenuItem>
        </ChildContent>
    </MudMenu>
</MudStack>

<MudDataGrid T="User" ServerData="LoadServerDataAsync" @ref="_grid">
    <Columns>
        <PropertyColumn Property="x => x.Id" Title="ID" />
        <PropertyColumn Property="x => x.Name" Title="Name" />
        <PropertyColumn Property="x => x.Email" Title="Email" />
        <TemplateColumn Title="Actions" Sortable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteUser(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="User" />
    </PagerContent>
</MudDataGrid>

@code {
    private MudDataGrid<User> _grid = default!;

    private async Task<GridData<User>> LoadServerDataAsync(GridState<User> state)
    {
        var result = await UserService.QueryAsync(
            skip: state.Page * state.PageSize,
            take: state.PageSize);

        return new GridData<User>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OpenCreateUserDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = DialogService.Show<CreateUserDialog>("Create user", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await _grid.ReloadServerData();
            Snackbar.Add("User created", Severity.Success);
        }
    }

    private async Task OpenBulkImportDialog()
    {
        var dialog = DialogService.Show<BulkImportDialog>("Bulk import");
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await _grid.ReloadServerData();
        }
    }

    private async Task DeleteUser(User user)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Confirm delete",
            $"Delete {user.Name}? This cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirm == true)
        {
            await UserService.DeleteAsync(user.Id);
            await _grid.ReloadServerData();
            Snackbar.Add("User deleted", Severity.Info);
        }
    }

    private void ExportToCsv()
    {
        Snackbar.Add("Export started", Severity.Info, config =>
        {
            config.Action = "View";
            config.OnClick = snackbar =>
            {
                // navigate to exports page
                return Task.CompletedTask;
            };
        });
    }
}
