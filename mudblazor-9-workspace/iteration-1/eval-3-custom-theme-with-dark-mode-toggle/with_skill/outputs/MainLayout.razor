@inherits LayoutComponentBase
@inject IJSRuntime JS

<MudThemeProvider @ref="_mudThemeProvider"
                  Theme="_theme"
                  @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Acme Dashboard</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All">Home</MudNavLink>
            <MudNavLink Href="/users" Match="NavLinkMatch.Prefix">Users</MudNavLink>
            <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = default!;
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _userPreferenceLoaded;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0EA5E9",
            Secondary = "#64748B"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#0EA5E9",
            Secondary = "#64748B"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px",
            DrawerWidthLeft = "280px"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        // Try to load the user's saved preference first; fall back to the OS preference.
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
            if (!string.IsNullOrEmpty(saved))
            {
                _isDarkMode = saved == "true";
                _userPreferenceLoaded = true;
            }
        }
        catch
        {
            // Prerender or JS unavailable — ignore and fall through to OS preference.
        }

        if (!_userPreferenceLoaded)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
        }

        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        _userPreferenceLoaded = true;

        try
        {
            await JS.InvokeVoidAsync(
                "localStorage.setItem",
                "darkMode",
                _isDarkMode.ToString().ToLower());
        }
        catch
        {
            // JS unavailable — state still flips in-memory for the session.
        }
    }
}
